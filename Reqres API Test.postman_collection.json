        {
          "name": "TC-SU-001 - Single User - valid existing user ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains data and support\", function () {\r",
                  "    pm.expect(res).to.have.property(\"data\");\r",
                  "    pm.expect(res).to.have.property(\"support\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"data is an object\", function () {\r",
                  "    pm.expect(res.data).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"data contains required user fields\", function () {\r",
                  "    pm.expect(res.data).to.have.property(\"id\");\r",
                  "    pm.expect(res.data).to.have.property(\"email\");\r",
                  "    pm.expect(res.data).to.have.property(\"first_name\");\r",
                  "    pm.expect(res.data).to.have.property(\"last_name\");\r",
                  "    pm.expect(res.data).to.have.property(\"avatar\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User ID equals 2\", function () {\r",
                  "    pm.expect(res.data.id).to.eql(2);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
