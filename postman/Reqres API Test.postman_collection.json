          "name": "TC-CU-001 - Create User - valid name and job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "const reqBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains required fields\", function () {\r",
                  "    pm.expect(res).to.have.property(\"name\");\r",
                  "    pm.expect(res).to.have.property(\"job\");\r",
                  "    pm.expect(res).to.have.property(\"id\");\r",
                  "    pm.expect(res).to.have.property(\"createdAt\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Returned name matches request body\", function () {\r",
                  "    pm.expect(res.name).to.eql(reqBody.name);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Returned job matches request body\", function () {\r",
                  "    pm.expect(res.job).to.eql(reqBody.job);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"id is not empty\", function () {\r",
                  "    pm.expect(res.id).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"createdAt is not empty\", function () {\r",
                  "    pm.expect(res.createdAt).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
