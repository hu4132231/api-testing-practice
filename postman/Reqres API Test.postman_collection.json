      "item": [
        {
          "name": "TC-LU-001 - List Users - valid page 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains pagination fields\", function () {\r",
                  "    pm.expect(res).to.have.property(\"page\");\r",
                  "    pm.expect(res).to.have.property(\"per_page\");\r",
                  "    pm.expect(res).to.have.property(\"total\");\r",
                  "    pm.expect(res).to.have.property(\"total_pages\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains data field\", function () {\r",
                  "    pm.expect(res).to.have.property(\"data\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"data is an array\", function () {\r",
                  "    pm.expect(res.data).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"page equals 2\", function () {\r",
                  "    pm.expect(res.page).to.eql(2);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
